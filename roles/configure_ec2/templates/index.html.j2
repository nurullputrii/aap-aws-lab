<!DOCTYPE html>
<html>
<head><title>{{ app_name }} v{{ app_version }}</title></head>
<body>
  <h1>{{ app_name }}</h1>
  <p>Version: {{ app_version }}</p>
  <p>Hostname: {{ ansible_hostname }}</p>
  <p>IP Address: {{ ansible_default_ipv4.address }}</p>
  <p>Environment: {{ hostvars[inventory_hostname]["tags"]["Env"] | default("unknown") }}</p>
  <p>Deployed by: Ansible Automation Platform</p>
  <p>Deploy time: {{ ansible_date_time.iso8601 }}</p>
</body>
</html>

